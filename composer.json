{
    "name": "misaf/laravel-email-webhooks",
    "description": "Core package for handling email webhook events in Laravel applications.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "email",
        "webhook",
        "event",
        "integration"
    ],
    "authors": [
        {
            "name": "Ehsan Mahmoodi",
            "email": "misaf.1990@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/support": "^13.0",
        "spatie/laravel-webhook-client": "^3.4.3",
        "spatie/laravel-package-tools": "^1.92"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "pestphp/pest-plugin-profanity": "^4.2.1",
        "pestphp/pest-plugin-type-coverage": "^4.0.3",
        "orchestra/testbench": "^11.0",
        "larastan/larastan": "^3.0"
    },
    "scripts": {
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage"
    },
    "autoload": {
        "psr-4": {
            "Misaf\\LaravelEmailWebhooks\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Misaf\\LaravelEmailWebhooks\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Misaf\\LaravelEmailWebhooks\\EmailWebhooksServiceProvider"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
